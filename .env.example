# MySQL source server — used by mysql_distillery.
# Copy to .env and fill in real values. .env is gitignored.

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=rootpass
# Database(s) to distill. Single name or comma-separated list for multi-DB.
# Each DB's artifacts land in $OUTPUT_DIR/<database>/.
MYSQL_DATABASES=mydb,mydb_audit

# Where distilled snapshot artifacts are written.
OUTPUT_DIR=./snapshots
